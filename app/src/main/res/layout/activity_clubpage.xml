<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F3F7"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Klub név -->
        <TextView
            android:id="@+id/club_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Klub neve"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#6A1B9A"
            android:paddingBottom="8dp"/>

        <!-- Admin -->
        <TextView
            android:id="@+id/club_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin: valaki@email.com"
            android:textSize="14sp"
            android:textColor="#6A1B9A"
            android:paddingBottom="16dp"/>

        <!-- Könyv Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#EDE7F6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/club_book_cover"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Borító"
                    android:background="#D1C4E9"
                    android:clipToOutline="true"/>

                <TextView
                    android:id="@+id/club_book_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Könyv címe"
                    android:textSize="16sp"
                    android:textColor="#4A148C"
                    android:layout_marginStart="16dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:layout_weight="1"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fejezetek Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F3E5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:text="Fejezetek"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#6A1B9A"
                    android:paddingBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/chapters_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Egyedi szobák Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#E1BEE7">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:text="Egyedi szobák"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#6A1B9A"
                    android:paddingBottom="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/customs_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Státusz -->
        <TextView
            android:id="@+id/club_public_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Publikus"
            android:textSize="14sp"
            android:textColor="#6A1B9A"
            android:paddingBottom="16dp"/>
    </LinearLayout>
</ScrollView>
