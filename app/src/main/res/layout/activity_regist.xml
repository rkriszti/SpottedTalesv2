<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/regist"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".RegistActivity">


    <EditText
        android:id="@+id/registemail"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:hint="Email cím"
        android:inputType="textEmailAddress"

        android:textColor="@color/white"
        android:textColorHint="@color/lightbordo"
        app:layout_constraintBottom_toTopOf="@+id/registusername"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.872"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.96" />

    <EditText
        android:id="@+id/registusername"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:hint="Felhasználónév"

        android:inputType="text"
        android:textColor="@color/white"
        android:textColorHint="@color/lightbordo"
        app:layout_constraintBottom_toTopOf="@+id/registpassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.872"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/registpassword"
        android:layout_width="211dp"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:hint="Jelszó"

        android:inputType="textPassword"
        android:textColor="@color/white"
        android:textColorHint="@color/lightbordo"
        app:layout_constraintBottom_toTopOf="@+id/registpasswordagain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.92"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/registpasswordagain"
        android:layout_width="211dp"
        android:layout_height="48dp"
        android:layout_marginBottom="20dp"
        android:hint="Jelszó újra"

        android:inputType="textPassword"
        android:textColor="@color/white"
        android:textColorHint="@color/lightbordo"
        app:layout_constraintBottom_toTopOf="@+id/registbutton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.92"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints" />


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/registbutton"
        android:layout_width="131dp"
        android:layout_height="57dp"
        android:layout_marginBottom="104dp"
        android:background="@drawable/rounded_button"
        android:radius="40dp"
        android:text="Regisztráció"
        android:textColor="#920553"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/registbuttongoogle"
        app:layout_constraintHorizontal_bias="0.95"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/registbuttongoogle"
        android:layout_width="100dp"
        android:layout_height="56dp"
        android:layout_marginBottom="104dp"
        android:background="@drawable/rounded_button"
        android:radius="40dp"
        android:text="Google"
        android:textColor="#920553"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent" />


    <TextView
        android:id="@+id/registtologin"
        android:layout_width="151dp"
        android:layout_height="25dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Van már fiókod?"
        android:textColor="@color/lightbordo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.842"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/registbutton"
        app:layout_constraintVertical_bias="0.0" />


    <ImageView
        android:id="@+id/giraffestart"
        android:layout_width="392dp"
        android:layout_height="629dp"
        android:layout_marginStart="-60dp"
        android:clickable="false"
        android:focusable="false"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/registemail"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/mediumgiraffe"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/welcome"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#80FFFFFF"

        android:fontFamily="cursive"
        android:gravity="center"
        android:shadowColor="#66033B"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:text="Spotted Tales"
        android:textColor="#FDFDFE"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.041" />
</androidx.constraintlayout.widget.ConstraintLayout>