<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:background="#A969185A"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/background_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/top_nav_menu"
        app:title="Spotted Tales"
        app:titleTextColor="@color/white" />

    <!-- ===== PROFIL HEADER ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/profileHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profile_pic"
                android:layout_width="91dp"
                android:layout_height="81dp"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_avatar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/white"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/profile_username"
                android:layout_width="206dp"
                android:layout_height="27dp"
                android:layout_marginStart="16dp"
                android:text="Adatok betöltése..."
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/profile_pic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@id/profile_pic"
                app:layout_constraintTop_toTopOf="@id/profile_pic"
                app:layout_constraintVertical_bias="0.511" />

            <EditText
                android:id="@+id/profile_username_edittext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Username"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/profile_pic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profile_pic"
                app:layout_constraintTop_toTopOf="@id/profile_pic" />

            <ImageView
                android:id="@+id/profile_edit"
                android:layout_width="37dp"
                android:layout_height="39dp"
                android:background="@drawable/ic_setting"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/profile_username"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.515" />

            <ImageView
                android:id="@+id/profile_save"
                android:layout_width="37dp"
                android:layout_height="39dp"
                android:background="@drawable/ic_save"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/profile_username"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.515" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== KEDVENC KÖNYVEK ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/favoriteBooks"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/profileHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="Kedvenc Könyvek:"
                app:layout_constraintBottom_toTopOf="@+id/bookSecond"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <ImageView
                android:id="@+id/bookFirst"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.511"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/delete_first"
                android:visibility="gone"
                android:layout_width="31dp"
                android:layout_height="29dp"
                android:layout_marginBottom="151dp"
                android:background="@drawable/ic_delete"
                app:layout_constraintBottom_toBottomOf="@+id/bookFirst"
                app:layout_constraintEnd_toEndOf="@+id/bookFirst"
                app:layout_constraintStart_toStartOf="@+id/bookFirst"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/bookFirstTitle"
                android:layout_width="77dp"
                android:layout_height="20dp"
                android:layout_marginTop="16dp"
                android:text="Válassz!"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/bookFirst"
                app:layout_constraintStart_toStartOf="@id/bookFirst"
                app:layout_constraintTop_toBottomOf="@id/bookFirst" />



            <ImageView
                android:id="@+id/bookSecond"
                android:layout_width="90dp"
                android:layout_height="140dp"
                android:layout_marginEnd="16dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="@id/bookFirst"
                app:layout_constraintEnd_toStartOf="@id/bookFirst" />

            <ImageView
                android:id="@+id/delete_second"
                android:visibility="gone"
                android:layout_width="31dp"
                android:layout_height="29dp"
                android:background="@drawable/ic_delete"
                app:layout_constraintBottom_toBottomOf="@+id/bookSecond"
                app:layout_constraintEnd_toEndOf="@+id/bookSecond"
                app:layout_constraintStart_toStartOf="@+id/bookSecond"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.298" />

            <ImageView
                android:layout_width="41dp"
                android:layout_height="36dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/ic_first"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/bookFirstTitle"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/bookSecondTitle"
                app:layout_constraintTop_toBottomOf="@+id/bookFirst"
                app:layout_constraintVertical_bias="0.0" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="39dp"
                android:background="@drawable/ic_second"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/bookSecondTitle"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bookSecond" />

            <!-- 3. hely -->
            <TextView
                android:id="@+id/bookSecondTitle"
                android:layout_width="59dp"
                android:layout_height="16dp"
                android:layout_marginTop="4dp"
                android:text="Válassz!"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/bookSecond"
                app:layout_constraintStart_toStartOf="@id/bookSecond"
                app:layout_constraintTop_toBottomOf="@id/bookSecond" />




            <ImageView
                android:id="@+id/bookThird"
                android:layout_width="90dp"
                android:layout_height="140dp"
                android:layout_marginStart="16dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="@id/bookFirst"
                app:layout_constraintStart_toEndOf="@id/bookFirst" />

            <ImageView
                android:id="@+id/delete_third"
                android:visibility="gone"
                android:layout_width="31dp"
                android:layout_height="29dp"
                android:background="@drawable/ic_delete"
                app:layout_constraintBottom_toBottomOf="@+id/bookThird"
                app:layout_constraintEnd_toEndOf="@+id/bookThird"
                app:layout_constraintStart_toStartOf="@+id/bookThird"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.264" />
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/ic_third"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/bookThirdTitle"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/bookFirstTitle"
                app:layout_constraintTop_toBottomOf="@+id/bookThird"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/bookThirdTitle"
                android:layout_width="78dp"
                android:layout_height="20dp"
                android:text="Válassz!"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/bookThird"
                app:layout_constraintHorizontal_bias="0.729"
                app:layout_constraintStart_toStartOf="@id/bookThird"
                app:layout_constraintTop_toBottomOf="@id/bookThird"
                app:layout_constraintVertical_bias="0.555" />




            </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

            <!-- ===== GOODREADS ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/goodreads"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/white"
                app:layout_constraintTop_toBottomOf="@id/favoriteBooks"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/goodreadsTitle"
                        android:layout_width="298dp"
                        android:layout_height="33dp"
                        android:text="Véletlenszerű könyajánlás goodreadsről? "
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/goodreadshelp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ToggleButton
                        android:id="@+id/goodreadshelp"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent"
                        android:text="Útmutató a kiexportáláshoz"
                        android:textOff="'?'"
                        android:textOn="'?'"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/goodreadsTitle" />


                    <Button
                        android:id="@+id/buttonimport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="28dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/darkpurple"
                        android:text="CSV importálása"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/goodreadsTitle"
                        app:layout_constraintVertical_bias="0.0" />

                    <Button
                        android:id="@+id/buttonchoose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/darkpurple"
                        android:text="Mit olvassak?"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.509"
                        app:layout_constraintStart_toEndOf="@+id/buttonimport" />


                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>



        <androidx.cardview.widget.CardView
            android:id="@+id/profile_delete_card"
            android:layout_width="0dp"
            android:layout_height="77dp"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/goodreads"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <Button
                    android:id="@+id/deleteprofile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#F44336"
                    android:text="Fiók törlése"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_nav"
            app:itemIconTint="@color/white"
            app:itemTextColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:menu="@menu/bottom_nav_menu"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_add_emoji"
            app:backgroundTint="#3c0c3e"
            app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="-28dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:menu="@menu/side_menu" />

</androidx.drawerlayout.widget.DrawerLayout>



