<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Goodreads Export Útmutató"
            android:textColor="#333333"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/holo_orange_light"
            android:backgroundTint="#FFF3CD"
            android:padding="12dp"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Fontos: Csak böngészőben működik, a Goodreads appban nem!"
                android:textColor="#856404"
                android:textSize="14sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Nyisd meg az export oldalt:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://www.goodreads.com/review/import"
            android:autoLink="web"
            android:paddingBottom="12dp"
            android:textColorLink="#007bff" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Kattints az 'Export Library' gombra."
            android:textStyle="bold"
            android:textSize="16sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:layout_marginVertical="12dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"

                android:src="@drawable/export" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Töltsd le a fájlt"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Várd meg a generálást, majd kattints a kék 'Your Export from...' linkre."
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Importálás"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A kapott .csv fájlt most már beolvashatod a profilodnál."
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jó szórakozást! 📚"
            android:gravity="center_horizontal"
            android:textSize="18sp"
            android:textStyle="italic"
            android:textColor="#666666" />

    </LinearLayout>
</ScrollView>